{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "cogeval.cog_case.v3" },
    "test_case_id": { "minLength": 1, "type": "string" },
    "cog_case_display_id": { "minLength": 1, "type": "string" },
    "source_id": { "minLength": 1, "type": "string" },
    "external_id": { "minLength": 1, "type": "string" },
    "title": { "minLength": 1, "type": "string" },
    "original_url": { "type": ["string", "null"] },
    "labels": { "type": "object" },
    "semantic_profile": { "type": "object" },
    "semantic_version": { "type": ["string", "null"] },
    "interpretation": { "type": ["string", "null"] },
    "online_at": { "type": ["string", "null"] },
    "promoted_at": { "minLength": 1, "type": "string" },
    "environment_requirements": {
      "items": { "$ref": "#/$defs/environment_requirement" },
      "type": "array"
    }
  },
  "required": ["schema", "test_case_id", "cog_case_display_id", "source_id", "external_id", "title", "promoted_at"],
  "type": "object",
  "$defs": {
    "environment_requirement": {
      "additionalProperties": false,
      "properties": {
        "id": { "enum": ["docker_engine", "go_toolchain"], "type": "string" },
        "kind": { "enum": ["container_engine", "host_toolchain"], "type": "string" },
        "display_name": { "minLength": 1, "type": "string" },
        "required": { "default": true, "type": "boolean" },
        "version_constraint": { "type": ["string", "null"] },
        "applies_to": {
          "items": { "enum": ["workspace_prepare", "candidate_execution", "official_validation"], "type": "string" },
          "type": "array"
        },
        "reason": { "type": ["string", "null"] }
      },
      "required": ["id", "kind", "display_name"],
      "type": "object"
    }
  }
}
