{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "case": {
      "additionalProperties": false,
      "properties": {
        "schema": {
          "const": "cogeval.cog_case.v1"
        },
        "test_case_id": {
          "minLength": 1,
          "type": "string"
        },
        "cog_case_display_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_id": {
          "minLength": 1,
          "type": "string"
        },
        "external_id": {
          "minLength": 1,
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "type": "string"
        },
        "original_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "labels": {
          "type": "object"
        },
        "semantic_profile": {
          "type": "object"
        },
        "semantic_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "interpretation": {
          "type": [
            "string",
            "null"
          ]
        },
        "online_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "promoted_at": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema",
        "test_case_id",
        "source_id",
        "external_id",
        "title",
        "promoted_at"
      ],
      "type": "object"
    },
    "time_scope": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "minLength": 1,
          "type": "string"
        },
        "starts_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "ends_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "label"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "cogeval.cog_case_group.v1"
    },
    "group_id": {
      "minLength": 1,
      "type": "string"
    },
    "slug": {
      "minLength": 1,
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "theme_tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "time_scope": {
      "anyOf": [
        {
          "$ref": "#/$defs/time_scope"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "enum": [
        "draft",
        "published",
        "archived"
      ]
    },
    "visibility": {
      "enum": [
        "internal",
        "public"
      ]
    },
    "selection_mode": {
      "enum": [
        "manual",
        "rule_snapshot"
      ]
    },
    "selection_filters": {
      "type": "object"
    },
    "member_count": {
      "minimum": 0,
      "type": "integer"
    },
    "members": {
      "items": {
        "$ref": "#/$defs/case"
      },
      "type": "array"
    },
    "created_at": {
      "minLength": 1,
      "type": "string"
    },
    "updated_at": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema",
    "group_id",
    "slug",
    "name",
    "created_at",
    "updated_at"
  ],
  "type": "object"
}
