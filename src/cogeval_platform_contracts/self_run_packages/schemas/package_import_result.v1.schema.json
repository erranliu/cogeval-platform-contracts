{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "record_import_result": {
      "additionalProperties": false,
      "properties": {
        "external_case_ref": {
          "minLength": 1,
          "type": "string"
        },
        "accepted": {
          "type": "boolean"
        },
        "test_result_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "queued_for_review": {
          "type": "boolean"
        },
        "review_item_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "external_case_ref",
        "accepted"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "cogeval.package_import_result.v1"
    },
    "package_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "snapshot_id": {
      "minLength": 1,
      "type": "string"
    },
    "n_accepted": {
      "minimum": 0,
      "type": "integer"
    },
    "n_rejected": {
      "minimum": 0,
      "type": "integer"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/record_import_result"
      },
      "type": "array"
    }
  },
  "required": [
    "schema",
    "snapshot_id",
    "n_accepted",
    "n_rejected",
    "results"
  ],
  "type": "object"
}
